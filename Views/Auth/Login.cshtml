@model LoginViewModel
@{
    ViewData["Title"] = "Вход";
}

<div class="row justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="col-md-4">
        <div class="card shadow-lg">
            <div class="card-header bg-primary text-white text-center">
                <h4 class="mb-0">🔐 Вход в системата</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-bold">Имейл</label>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="your@email.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label fw-bold">Парола</label>
                        <input asp-for="Password" class="form-control form-control-lg" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg">Вход</button>
                    </div>
                    
                    <div class="text-center">
                        <p class="mb-0">Нямате акаунт? <a asp-action="Register" class="text-decoration-none">Регистрирайте се тук</a></p>
                        <hr class="my-3">
                        <p class="mb-2 small text-muted">За достъп до мениджърските отчети:</p>
                        <a href="/Setup/CreateManager" class="btn btn-outline-warning btn-sm">
                            👤 Създай Мениджър акаунт
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
